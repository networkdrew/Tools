---
/**
 * Inlines a Lucide SVG at build time (zero runtime JS/network cost).
 * Add new icons by copying the source SVG from lucide-static/icons into
 * src/icons/ and adding its name to the IconName union below.
 */
const icons = import.meta.glob<string>("/src/icons/*.svg", {
  query: "?raw",
  import: "default",
  eager: true,
});

export type IconName =
  | "check"
  | "chevron-down"
  | "circle-x"
  | "contrast"
  | "copy"
  | "download"
  | "image"
  | "lock"
  | "menu"
  | "moon"
  | "repeat"
  | "search"
  | "shield-check"
  | "sun"
  | "terminal"
  | "type"
  | "x";

interface Props {
  name: IconName;
  class?: string;
  "aria-hidden"?: boolean;
}

const {
  name,
  class: className,
  "aria-hidden": ariaHidden = true,
} = Astro.props;
const raw = icons[`/src/icons/${name}.svg`];
if (!raw) {
  throw new Error(`Unknown icon "${name}" — add src/icons/${name}.svg first`);
}

const svg = raw
  .replace(
    "<svg",
    `<svg class="${className ?? ""}" aria-hidden="${ariaHidden}"`,
  )
  .replace(' width="24"', "")
  .replace(' height="24"', "");
---

<Fragment set:html={svg} />
