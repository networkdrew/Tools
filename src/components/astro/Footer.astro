---
import { SITE_DESCRIPTION, SITE_NAME } from "@/lib/config/site";
import { categories } from "@/lib/tools/categories";
---

<footer class="border-border bg-bg border-t">
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
      <div>
        <p class="text-text text-sm font-bold">{SITE_NAME}</p>
        <p class="text-text-muted mt-2 max-w-sm text-sm">{SITE_DESCRIPTION}</p>
      </div>

      <div>
        <p class="text-text text-sm font-semibold">Categories</p>
        <ul class="mt-2 flex flex-col gap-1.5">
          {
            categories.map((category) => (
              <li>
                <a
                  href={`/categories/${category.id}/`}
                  class="text-text-muted hover:text-text text-sm hover:underline"
                >
                  {category.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <p class="text-text text-sm font-semibold">Privacy</p>
        <p class="text-text-muted mt-2 max-w-sm text-sm">
          Every tool listed as "runs in your browser" processes your input
          entirely on your device. Nothing you type or upload into those tools
          is sent to a server.
        </p>
        <a
          href="/tools/"
          class="text-accent mt-2 inline-block text-sm hover:underline"
        >
          Browse all tools →
        </a>
      </div>
    </div>

    <div
      class="border-border text-text-muted mt-8 flex flex-col gap-2 border-t pt-6 text-sm sm:flex-row sm:items-center sm:justify-between"
    >
      <p>&copy; {new Date().getFullYear()} {SITE_NAME}. Free to use.</p>
    </div>
  </div>
</footer>
