    "astro": "^7.1.3",
    "fuse.js": "^7.5.0",
    "onnxruntime-web": "^1.27.0",
    "qrcode-generator": "^2.0.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.3",
