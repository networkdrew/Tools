# eslint-plugin-jsx-a11y@6.10.2 has not yet published a peer range covering
# ESLint 10 (which eslint-plugin-astro requires). The plugin's rules are
# plain AST checks and work fine on ESLint 10 in practice; this is a
# metadata lag, not a real incompatibility. Revisit when jsx-a11y bumps
# its peerDependencies.
legacy-peer-deps=true
